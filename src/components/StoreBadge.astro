---
export interface Props {
  kind: "ios" | "android";
  soon?: boolean;
  href?: string;
}
const { kind, soon = true, href = "#" } = Astro.props;
const isIos = kind === "ios";
const isExternal = href.startsWith("http");
---
<a
  href={href}
  class="store-badge"
  aria-label={`${soon ? "Coming soon to" : "Download on"} ${isIos ? "the App Store" : "Google Play"}`}
  {...isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {}}
>
  <span class="store-badge-icon">
    {isIos ? (
      <svg width="22" height="26" viewBox="0 0 24 28" fill="currentColor">
        <path d="M17.5 14.8c0-2.7 2.2-4 2.3-4.1-1.3-1.8-3.2-2.1-3.9-2.1-1.7-.2-3.2.9-4.1.9-.8 0-2.1-.9-3.5-.9-1.8 0-3.5 1-4.4 2.6-1.9 3.2-.5 8 1.4 10.6.9 1.3 2 2.7 3.4 2.6 1.4-.1 1.9-.9 3.5-.9s2.1.9 3.5.9c1.5 0 2.4-1.3 3.3-2.6 1-1.5 1.5-2.9 1.5-3-.1 0-2.9-1.1-3-4z" />
        <path d="M14.8 7c.8-1 1.4-2.3 1.2-3.7-1.2.1-2.6.8-3.4 1.8-.7.9-1.4 2.2-1.2 3.5 1.3.1 2.6-.7 3.4-1.6z" />
      </svg>
    ) : (
      <svg width="22" height="26" viewBox="0 0 24 28" fill="none">
        <path d="M4 4 L18 14 L4 24 Z" fill="currentColor" opacity="0.95" />
        <path d="M4 4 L13 14 L4 24" stroke="currentColor" stroke-width="0.5" opacity="0.5" fill="none" />
      </svg>
    )}
  </span>
  <span class="store-badge-text">
    <span class="store-badge-sub">{soon ? "Coming soon to" : "Download on"}</span>
    <span class="store-badge-big">{isIos ? "App Store" : "Google Play"}</span>
  </span>
</a>

<style>
  .store-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 18px 10px 14px;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
    min-width: 200px;
    transition: transform 200ms ease;
  }
  .store-badge:hover { transform: translateY(-1px); }
  .store-badge-icon {
    width: 28px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .store-badge-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .store-badge-sub {
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.72;
    font-family: var(--mono);
    white-space: nowrap;
  }
  .store-badge-big {
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin-top: 2px;
    font-family: var(--sans);
  }
</style>
