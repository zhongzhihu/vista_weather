---
// iPhone mockup with the Vista Weather app screen.
// Pure HTML/CSS — no JS — fully indexable and lightning-fast.
import { CITIES, type City } from "../data/cities";
import WxIcon from "./WxIcon.astro";

export interface Props {
  cityKey: keyof typeof CITIES | string;
  scale?: number;
  rotate?: number;
  x?: number;
  y?: number;
  z?: number;
  featured?: boolean;
}

const {
  cityKey,
  scale = 1,
  rotate = 0,
  x = 0,
  y = 0,
  z = 1,
  featured = false,
} = Astro.props;

const city: City = CITIES[cityKey] ?? CITIES.sf;

const wrapperTransform = `translate(-50%, -50%) translate(${x}px, ${y}px) rotate(${rotate}deg) scale(${scale})`;
const wrapperFilter = featured
  ? "drop-shadow(0 40px 60px rgba(17,15,12,0.30)) drop-shadow(0 12px 24px rgba(17,15,12,0.22))"
  : "drop-shadow(0 28px 44px rgba(17,15,12,0.20)) drop-shadow(0 8px 18px rgba(17,15,12,0.18))";
---

<div
  class="phone-wrapper"
  style={`transform:${wrapperTransform};z-index:${z};filter:${wrapperFilter};`}
>
  <div class="phone-bezel">
    <div class="phone-rim"></div>
    <div class="phone-screen">
      <!-- Background photo -->
      <img class="phone-photo" src={city.photo} alt={`${city.name} weather`} loading="lazy" draggable="false" />
      <div class="phone-vignette"></div>

      <!-- Status bar -->
      <div class="phone-statusbar">
        <div class="ios phone-time">{city.time}</div>
        <div class="phone-island"></div>
        <div class="phone-status-right">
          <svg width="16" height="11" viewBox="0 0 16 11" fill="white">
            <rect x="0"    y="7"   width="2.5" height="3.5" rx="0.6" />
            <rect x="3.7"  y="5"   width="2.5" height="5.5" rx="0.6" />
            <rect x="7.4"  y="3"   width="2.5" height="7.5" rx="0.6" />
            <rect x="11.1" y="0.5" width="2.5" height="10"  rx="0.6" />
          </svg>
          <svg width="16" height="11" viewBox="0 0 16 11" fill="white">
            <path d="M8 1 C 3 1 1 4 1 4 L 2.5 5.5 C 2.5 5.5 4.5 3 8 3 C 11.5 3 13.5 5.5 13.5 5.5 L 15 4 C 15 4 13 1 8 1 Z" />
            <path d="M8 4.5 C 5 4.5 3.5 6.5 3.5 6.5 L 5 8 C 5 8 6 6.5 8 6.5 C 10 6.5 11 8 11 8 L 12.5 6.5 C 12.5 6.5 11 4.5 8 4.5 Z" />
            <circle cx="8" cy="9" r="1.3" />
          </svg>
          <svg width="26" height="12" viewBox="0 0 26 12" fill="none">
            <rect x="0.5" y="0.5" width="22" height="11" rx="2.5" stroke="white" stroke-opacity="0.7" />
            <rect x="2"   y="2"   width="19" height="8"  rx="1.5" fill="white" />
            <rect x="23"  y="3.5" width="1.8" height="5" rx="0.8" fill="white" opacity="0.7" />
          </svg>
        </div>
      </div>

      <!-- Header: city name + caption -->
      <div class="phone-header">
        <div class="phone-header-btn">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.6" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="14" rx="2.5" />
            <circle cx="9" cy="10" r="1.6" fill="white" stroke="none" />
            <path d="M3 17 L9 12 L14 16 L17 13 L21 17" />
          </svg>
        </div>
        <div class="phone-header-center">
          <div class="ios phone-city">{city.name}</div>
          <div class="ios phone-region">{city.region}</div>
          <div class="ios phone-caption">{city.caption}</div>
        </div>
        <div class="phone-header-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
            <circle cx="6"  cy="12" r="1.6" />
            <circle cx="12" cy="12" r="1.6" />
            <circle cx="18" cy="12" r="1.6" />
          </svg>
        </div>
      </div>

      <!-- Bottom: forecast strip + tab bar -->
      <div class="phone-forecast-wrap">
        <div class="phone-forecast-blur"></div>
        <div class="phone-forecast-row">
          {city.hours.map((h) => (
            <div class="phone-hour-cell">
              <div class="ios phone-hour-label">{h.t}</div>
              <div style="height:4px"></div>
              <WxIcon kind={h.icon} size={26} />
              <div style="height:6px"></div>
              <div class="ios phone-hour-temp">{h.v}°</div>
            </div>
          ))}
        </div>
        <div style="height:14px"></div>
        <div class="phone-tabbar">
          <div class="phone-tab phone-tab-active">
            <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
              <circle cx="22" cy="11" r="4" fill="#ffd147" />
              <path d="M8 22 Q4 22 4 18 Q4 14 8 14 Q9 10 14 10 Q20 10 21 16 Q25 16 25 20 Q25 24 21 24 H9 Q8 24 8 22Z" fill="#62b6ff" />
            </svg>
            <div class="ios phone-tab-label phone-tab-label-active">Weather</div>
          </div>
          <div class="phone-tab phone-tab-inactive">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linejoin="round">
              <rect x="3" y="6" width="16" height="13" rx="2" />
              <rect x="6" y="3" width="15" height="13" rx="2" />
            </svg>
            <div class="ios phone-tab-label">Photos</div>
          </div>
          <div class="phone-tab phone-tab-icon-only">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round">
              <circle cx="11" cy="11" r="6.5" />
              <path d="M16 16 L21 21" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .phone-wrapper {
    position: absolute;
    left: 50%;
    top: 50%;
    transition: transform 700ms cubic-bezier(.2,.7,.2,1);
    will-change: transform;
  }
  .phone-bezel {
    width: 300px;
    height: 620px;
    border-radius: 50px;
    background: linear-gradient(170deg, #2a2730 0%, #181719 50%, #0e0d10 100%);
    padding: 9px;
    position: relative;
    box-shadow:
      inset 0 0 0 1.5px rgba(255,255,255,0.07),
      inset 0 0 0 3px rgba(0,0,0,0.6);
  }
  .phone-rim {
    position: absolute;
    inset: 4px;
    border-radius: 47px;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
    pointer-events: none;
    z-index: 4;
  }
  .phone-screen {
    position: absolute;
    inset: 9px;
    border-radius: 42px;
    overflow: hidden;
    background: #7aa8d6;
  }
  .phone-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    user-select: none;
    pointer-events: none;
  }
  .phone-vignette {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(0,0,0,0.22) 0%,
        rgba(0,0,0,0.05) 18%,
        rgba(0,0,0,0)    30%,
        rgba(0,0,0,0)    70%,
        rgba(0,0,0,0.10) 100%);
    pointer-events: none;
  }
  .phone-statusbar {
    position: relative;
    height: 44px;
    padding: 0 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: white;
    z-index: 2;
  }
  .phone-time {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.01em;
    z-index: 2;
  }
  .phone-island {
    position: absolute;
    top: 9px;
    left: 50%;
    transform: translateX(-50%);
    width: 86px;
    height: 26px;
    border-radius: 18px;
    background: #000;
    z-index: 3;
  }
  .phone-status-right {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .phone-header {
    position: relative;
    display: grid;
    grid-template-columns: 40px 1fr 40px;
    align-items: start;
    padding: 6px 14px 0;
    color: white;
    z-index: 2;
  }
  .phone-header-btn {
    width: 34px;
    height: 34px;
    border-radius: 17px;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 4px;
  }
  .phone-header :global(.phone-header-btn:last-child) { margin-left: auto; }
  .phone-header-center {
    text-align: center;
    padding-top: 2px;
  }
  .phone-city {
    font-size: 18px;
    font-weight: 700;
    color: white;
    text-shadow: 0 1px 3px rgba(0,0,0,0.25);
    letter-spacing: -0.01em;
  }
  .phone-region {
    font-size: 11px;
    font-weight: 500;
    color: rgba(255,255,255,0.95);
    margin-top: 2px;
    text-shadow: 0 1px 2px rgba(0,0,0,0.25);
  }
  .phone-caption {
    font-size: 9.5px;
    font-weight: 400;
    color: rgba(255,255,255,0.95);
    margin-top: 6px;
    line-height: 1.35;
    text-shadow: 0 1px 2px rgba(0,0,0,0.25);
    padding: 0 4px;
  }
  .phone-forecast-wrap {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding-top: 10px;
    padding-bottom: 16px;
    z-index: 2;
  }
  .phone-forecast-blur {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.18) 22%, rgba(0,0,0,0.30) 100%);
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    pointer-events: none;
  }
  .phone-forecast-row {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    padding: 0 8px;
  }
  .phone-hour-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: white;
  }
  .phone-hour-label {
    font-size: 11px;
    font-weight: 500;
    opacity: 0.95;
    text-shadow: 0 1px 2px rgba(0,0,0,0.25);
  }
  .phone-hour-temp {
    font-size: 17px;
    font-weight: 700;
    text-shadow: 0 1px 2px rgba(0,0,0,0.25);
  }
  .phone-tabbar {
    position: relative;
    margin: 0 16px;
    height: 52px;
    border-radius: 26px;
    background: rgba(255,255,255,0.10);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid rgba(255,255,255,0.28);
    display: grid;
    grid-template-columns: 1.2fr 1fr 0.7fr;
    align-items: center;
    padding: 0 6px;
  }
  .phone-tab {
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    color: white;
  }
  .phone-tab-active {
    border-radius: 21px;
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.35);
    margin: 0 4px;
  }
  .phone-tab-label {
    font-size: 13px;
    font-weight: 500;
    text-shadow: 0 1px 2px rgba(0,0,0,0.2);
  }
  .phone-tab-label-active {
    color: #7ec1ff;
    font-weight: 600;
  }
</style>
