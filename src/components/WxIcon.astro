---
// Inline weather glyphs — pure SVG, no JS.
export interface Props {
  kind: "sun" | "cloud-sun" | "cloud" | "moon" | "cloud-night";
  size?: number;
}
const { kind, size = 26 } = Astro.props;
---
{kind === "sun" && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none">
    <circle cx="16" cy="16" r="6" fill="#ffd147" />
    {[0,45,90,135,180,225,270,315].map((a) => (
      <rect x="15.2" y="2" width="1.6" height="4" rx="0.8" fill="#ffd147" transform={`rotate(${a} 16 16)`} />
    ))}
  </svg>
)}
{kind === "cloud-sun" && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none">
    <circle cx="22" cy="10" r="4" fill="#ffd147" />
    <path d="M9 22 Q5 22 5 18 Q5 14 9 14 Q10 10 15 10 Q21 10 22 16 Q26 16 26 20 Q26 24 22 24 H10 Q9 24 9 22Z" fill="#ffffff" />
  </svg>
)}
{kind === "cloud" && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none">
    <path d="M8 22 Q4 22 4 18 Q4 13 9 13 Q10 8 16 8 Q23 8 24 15 Q28 15 28 19 Q28 24 23 24 H9 Q8 24 8 22Z" fill="#ffffff" />
  </svg>
)}
{kind === "moon" && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none">
    <path d="M22 20 A10 10 0 1 1 12 6 A8 8 0 0 0 22 20 Z" fill="#e9e1ce" />
  </svg>
)}
{kind === "cloud-night" && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none">
    <path d="M24 12 A6 6 0 1 1 18 6 A5 5 0 0 0 24 12 Z" fill="#e9e1ce" />
    <path d="M8 24 Q4 24 4 20 Q4 16 9 16 Q11 13 16 14 Q22 15 22 20 Q26 20 26 23 Q26 26 22 26 H9 Q8 26 8 24Z" fill="#ffffff" />
  </svg>
)}
