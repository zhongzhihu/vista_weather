---
import Layout from "../layouts/Layout.astro";
import StoreBadge from "../components/StoreBadge.astro";
import { Image } from "astro:assets";
import mockupsImage from "../images/Vista Weather Beautiful City & Nature Photos.png";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
const googleFormUrl = import.meta.env.PUBLIC_GOOGLE_FORM_URL || "";
const googleFormEmailEntry = import.meta.env.PUBLIC_GOOGLE_FORM_EMAIL_ENTRY || "";
---
<Layout>
  <div class="page">
    <div class="page-frame" aria-hidden="true"></div>

    <!-- Masthead -->
    <header class="masthead">
      <div class="wordmark">
        <span class="wordmark-name">Vista&nbsp;Weather</span>
      </div>
      <nav></nav>
    </header>

    <div class="rule" style="margin-top:14px"></div>

    <!-- Hero -->
    <main class="hero-grid">
      <section class="hero-left">
        <h1 class="headline">
          See the weather<br />
          <em>through the beauty</em><br />
          of each place.
        </h1>

        <p class="dek">
          A weather app that sets every forecast against a photograph of where you are.
        </p>

        <div class="cta-row">
          <StoreBadge kind="ios" soon={false} href="https://apps.apple.com/us/app/id6768575893" />
        </div>

        <form
          id="cta"
          class="waitlist"
          action={googleFormUrl}
          method="POST"
          target="hidden_iframe"
        >
          <label for="email-input" class="kicker" style="display:block;margin-bottom:8px">
            Join the Google Play Store waitlist
          </label>
          <div class="waitlist-row">
            <input
              id="email-input"
              type="email"
              name={googleFormEmailEntry}
              placeholder="your@address.com"
              required
            />
            <button type="submit">
              Notify&nbsp;me
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 8 H13 M9 4 L13 8 L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>
          <div id="form-message" class="kicker" style="margin-top:10px;color:var(--ink-3)">
            No spam · One letter at launch
          </div>
        </form>
        <iframe
          name="hidden_iframe"
          id="hidden_iframe"
          style="display:none;"
        ></iframe>
      </section>

      <section class="hero-right">
        <Image
          src={mockupsImage}
          alt="Vista Weather App screenshots showcasing beautiful city and nature photos"
          class="hero-mockups"
          loading="eager"
        />
      </section>
    </main>

    <div class="rule" style="margin:48px 0 32px"></div>

    <!-- App Details Section -->
    <section class="app-details" aria-label="App story and features">
      <div class="details-story">
        <p class="kicker">Why Vista Weather</p>
        <h2 class="serif-title">Designed by a data scientist to deliver clear, powerful, and beautiful forecasts.</h2>
        <div class="story-content">
          <p>
            I have often felt underwhelmed by the design, accuracy, and clutter of typical weather apps. Most of them force you to dig around just to answer the most basic questions:
          </p>
          <ul class="story-questions">
            <li>Will it rain?</li>
            <li>When will it start?</li>
            <li>When will it stop?</li>
          </ul>
          <p>
            Therefore, I have decided to build my own weather app. Vista Weather is designed to help you understand the weather in just a couple of seconds, while still offering advanced tools when you want to go deeper.
          </p>
        </div>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <span class="feature-num">01 / FORECAST CLARITY</span>
          <h3>Hyper-local rain forecasts</h3>
          <p>Get minute-by-minute rain forecasts for the next 4 hours, displaying exactly when precipitation starts and stops.</p>
        </div>
        <div class="feature-card">
          <span class="feature-num">02 / MODEL CONSENSUS</span>
          <h3>Compare Forecasts</h3>
          <p>View forecasts side-by-side across multiple data sources to understand uncertainty and different outcomes.</p>
        </div>
        <div class="feature-card">
          <span class="feature-num">03 / GLOBAL DATA</span>
          <h3>Most Advanced Data Sources</h3>
          <p>Provides forecasts from leading global models like Foreca alongside premier national bureaus—including the NWS (US), Deutscher Wetterdienst (DE), KNMI (Netherlands), and MET Norway.</p>
        </div>
        <div class="feature-card">
          <span class="feature-num">04 / EXTENDED OUTLOOK</span>
          <h3>30-Day Window</h3>
          <p>Plan ahead with a complete 30-day forecast view that lets you anticipate trends far in advance.</p>
        </div>
        <div class="feature-card">
          <span class="feature-num">05 / SYSTEM INTEGRATION</span>
          <h3>Home Screen Widgets</h3>
          <p>Access weather updates instantly with beautifully designed widgets that bring clarity directly to your home screen.</p>
        </div>
        <div class="feature-card">
          <span class="feature-num">06 / BEAUTIFUL PHOTOS</span>
          <h3>Contextual Backdrops</h3>
          <p>Curated photography from Pexels and Unsplash dynamically shows images matching your location, nearby cities, or current nature scenes.</p>
        </div>
      </div>
    </section>

    <div class="rule" style="margin:48px 0 32px"></div>

    <footer class="foot">
      <div class="kicker">Vista&nbsp;Weather&nbsp;&copy;&nbsp;2026</div>
      <div class="kicker" style="text-align:center">Now Available on iOS<br />Coming soon to Android</div>
      <div class="kicker" style="text-align:right">
        <a href={`${baseUrl.replace(/\/$/, "")}/support/`}>Support</a> &middot; <a href={`${baseUrl.replace(/\/$/, "")}/privacy/`}>Privacy</a>
      </div>
    </footer>
  </div>

  <style is:global>
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
  </style>

  <script is:inline>
    const form = document.getElementById("cta");
    const iframe = document.getElementById("hidden_iframe");
    const submitButton = form.querySelector("button[type='submit']");
    const originalBtnHtml = submitButton.innerHTML;
    const formMessage = document.getElementById("form-message");

    let submitted = false;

    form.addEventListener("submit", (e) => {
      const action = form.getAttribute("action");
      const emailInputName = form.querySelector("input[type='email']").getAttribute("name");

      if (!action || !emailInputName) {
        e.preventDefault();
        formMessage.style.color = "#ff4444";
        formMessage.textContent = "Error: Google Form settings are not configured in your .env file.";
        return;
      }

      submitted = true;
      submitButton.disabled = true;
      submitButton.innerHTML = `Adding... <svg class="animate-spin" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="animation: spin 1s linear infinite; display: inline-block; vertical-align: middle; margin-left: 4px;"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="2" stroke-dasharray="10 30" fill="none"></circle></svg>`;
    });

    iframe.addEventListener("load", () => {
      if (submitted) {
        formMessage.style.color = "var(--ink)";
        formMessage.textContent = "Success! You have been added to the waitlist.";
        form.reset();
        submitButton.innerHTML = "Success";
        submitted = false;
      }
    });
  </script>
</Layout>
